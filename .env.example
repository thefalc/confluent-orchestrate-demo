# Confluent Cloud
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
CONFLUENT_API_KEY=your-confluent-api-key
CONFLUENT_API_SECRET=your-confluent-api-secret
CONFLUENT_SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-east-1.aws.confluent.cloud
CONFLUENT_SR_API_KEY=your-sr-api-key
CONFLUENT_SR_API_SECRET=your-sr-api-secret

# Confluent Cloud REST API (for connector management)
CONFLUENT_CLOUD_API_KEY=your-cloud-api-key
CONFLUENT_CLOUD_API_SECRET=your-cloud-api-secret
CONFLUENT_ENVIRONMENT_ID=env-xxxxx
CONFLUENT_CLUSTER_ID=lkc-xxxxx

# watsonx Orchestrate
WXO_API_KEY=your-ibm-cloud-api-key
WXO_INSTANCE_URL=https://api.us-south.watsonx-orchestrate.cloud.ibm.com
WXO_AGENT_ID=your-agent-id

# Orchestrate Local (webhook proxy)
ORCHESTRATE_LOCAL_URL=http://localhost:4321
ORCHESTRATE_AGENT_ID=your-local-agent-id
JWT_SECRET=your-jwt-secret-from-server-env
DEFAULT_TENANT_ID=10000000-0000-0000-0000-000000000000

# Linear (for MCP toolkit)
LINEAR_API_KEY=lin_api_xxxxxxxxxxxx

# Optional: Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
